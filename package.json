{
  "name": "daber",
  "private": true,
  "version": "0.0.0",
  "description": "Hebrew handwriting practice monorepo (MVP scaffolding)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "npm run build:content && npm run build:web && npm run build:api",
    "build:content": "npm -w packages/content run build",
    "build:web": "npm -w apps/web run build",
    "build:api": "npm -w apps/api run build",
    "dev:api": "npm -w apps/api run dev",
    "dev:web": "npm -w apps/web run dev",
    "heroku-postbuild": "npm -w apps/api run prisma:generate && npm run build",
    "start": "node apps/api/dist/server.js",
    "export:calibration": "node scripts/export_calibration_png.cjs",
    "prepare:hhd": "python3 scripts/cnn_hhd/prepare_hhd_numeric.py --root data/hhd_dataset --out data/hhd_by_letter --mapping scripts/cnn_hhd/hhd_mapping.json"
  }
}
